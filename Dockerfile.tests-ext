ARG TARGETARCH

# Build the test extension binary
FROM docker.io/library/golang:1.25 as builder

ARG TARGETARCH=amd64

WORKDIR /opt/app-root

# Copy the go manifests and source
COPY go.mod go.mod
COPY go.sum go.sum
COPY vendor/ vendor/
COPY cmd/netobserv-tests-ext/ cmd/netobserv-tests-ext/
COPY integration-tests/ integration-tests/

# Build
RUN CGO_ENABLED=0 GOOS=linux GOARCH=$TARGETARCH GO111MODULE=on go build -mod vendor -a -o netobserv-tests-ext ./cmd/netobserv-tests-ext/

# Create final image from minimal + built binary
FROM --platform=linux/$TARGETARCH registry.access.redhat.com/ubi9/ubi-minimal:9.7-1773939694
WORKDIR /
COPY --from=builder /opt/app-root/netobserv-tests-ext .
# Copy testdata so runtime.Caller-based paths resolve correctly
COPY --from=builder /opt/app-root/integration-tests/backend/testdata /opt/app-root/integration-tests/backend/testdata
USER 65532:65532

ENTRYPOINT ["/netobserv-tests-ext"]
